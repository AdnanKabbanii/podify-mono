    "@mui/material": "^6.4.5",
    "@prisma/client": "^6.4.1",
    "axios": "^1.18.1",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "elevenlabs-node": "^2.0.3",
    "express": "^4.19.2",
    "framer-motion": "^12.4.7",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
